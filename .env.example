# =============================================================================
# Variaveis de ambiente - EXEMPLO
# =============================================================================
# INSTRUCOES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores reais no .env
#   3. NUNCA faca commit do .env (ele esta no .gitignore)
#
# No servidor de producao, o GitHub Actions atualiza APP_IMAGE e os valores
# nao sensiveis. Senhas devem vir de GitHub Secrets ou do .env do servidor.
# =============================================================================

# Imagem Docker da aplicacao
APP_IMAGE=ghcr.io/usuario/mercado:latest

# Porta publicada no servidor da equipe
SERVER_PORT=8113

# Banco de dados de producao
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/eq13
SPRING_DATASOURCE_USERNAME=eq13
SPRING_DATASOURCE_PASSWORD=troque-pela-senha-real
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=5

# Object Storage S3/MinIO
AWS_S3_ENDPOINT=http://minio:9000
AWS_S3_PUBLIC_ENDPOINT=https://s3.dsc.rodrigor.com
AWS_S3_REGION=us-east-1
AWS_S3_BUCKET=eq13
AWS_S3_ACCESS_KEY=eq13
AWS_S3_SECRET_KEY=troque-pela-chave-real
