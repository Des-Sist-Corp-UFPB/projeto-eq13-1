# =============================================================================
# Variaveis de ambiente - EXEMPLO
# =============================================================================
# INSTRUCOES:
#   1. Copie este arquivo: cp .env.example .env
#   2. Preencha os valores reais no .env
#   3. NUNCA faca commit do .env (ele esta no .gitignore)
#
# No servidor de producao, o GitHub Actions gera:
#   /opt/eq13/deploy.env
# A variavel APP_IMAGE tambem e atualizada automaticamente pelo GitHub Actions.
# =============================================================================

# Imagem Docker da aplicacao (atualizada automaticamente pelo CI/CD a cada deploy)
# Substitua "usuario" pelo seu usuario ou organizacao no GitHub.
APP_IMAGE=ghcr.io/usuario/mercado:latest

# Banco de dados de producao
DATABASE_URL=jdbc:postgresql://postgres:5432/eq13
DATABASE_USERNAME=eq13
DATABASE_PASSWORD=troque-por-uma-senha-forte

# Porta publicada no servidor
SERVER_PORT=8113
